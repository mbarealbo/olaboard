# Supabase — required
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Self-hosted mode — set to true to disable all plan limits and Stripe references.
# When enabled, all users get unlimited access regardless of their profile's plan field.
# Leave unset or set to false when running the managed cloud version.
VITE_SELF_HOSTED=true

# Stripe — only needed for the managed cloud version (leave empty for self-hosted)
VITE_STRIPE_MONTHLY_PRICE_ID=
VITE_STRIPE_YEARLY_PRICE_ID=
